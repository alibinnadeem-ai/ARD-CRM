# ─── ARD CRM — Environment Variables ──────────────────────────────────────────
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to version control.

# ── Database (REQUIRED) ─────────────────────────────────────────────────────
# Neon Postgres connection string
# Example:
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require&channel_binding=require
DATABASE_URL=

# ── Webhook Security (REQUIRED for inbound webhooks) ───────────────────────
# A random secure string — generate with: openssl rand -hex 32
WEBHOOK_SECRET=change-me-to-a-random-secure-string

# ── API Security (OPTIONAL) ────────────────────────────────────────────────
# Used to protect the /api/integrations/pull endpoint
API_SECRET_TOKEN=change-me-too

# ── CORS (OPTIONAL) ────────────────────────────────────────────────────────
# Restrict API access to your domain only
# ALLOWED_ORIGIN=https://your-ard-crm.vercel.app

# ── MultiTechno ERP (OPTIONAL — activate in lib/connectors/index.js) ───────
MULTITECHNO_API_URL=
MULTITECHNO_API_KEY=

# ── TeleCRM (OPTIONAL) ─────────────────────────────────────────────────────
TELECRM_API_URL=
TELECRM_API_KEY=

# ── Meta / Facebook Lead Ads (OPTIONAL) ────────────────────────────────────
META_ACCESS_TOKEN=
META_AD_ACCOUNT_ID=
